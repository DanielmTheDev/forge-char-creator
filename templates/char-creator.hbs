<form class="forge-char-creator-content standard-form flexcol">
<p class="hint">{{message}}</p>

<div class="form-group">
  <label for="charName">Character Name:</label>
  <div class="form-fields">
    <input type="text" id="charName" name="charName" placeholder="Enter name...">
  </div>
</div>
<div class="form-group portrait-group flexrow" style="align-items: center; margin-bottom: 10px;">
  <label for="portraitUpload" style="flex: 1;">Portrait Image:</label>
  <div class="form-fields" style="flex: 2; display: flex; align-items: center; gap: 10px;">
    <!-- The actual file input -->
    <input type="file" id="portraitUpload" name="portraitUpload" accept="image/*" style="width: 100%;">
    <!-- A small preview box to show what they picked -> defaults to mystery man -->
    <img id="portraitPreview" src="icons/svg/mystery-man.svg" alt="Preview" width="48" height="48" style="border: 1px solid #000; border-radius: 4px; object-fit: cover;">
  </div>
</div>

<div class="flexrow" style="gap: 10px; margin-bottom: 10px;">
  <!-- Actor Size -->
  <fieldset class="size-fieldset" style="flex: 1; margin: 0;">
    <legend>Actor Size</legend>
    <div class="form-fields" style="display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; font-size: 0.95rem;">
      <label><input type="radio" name="size" value="tiny"> Tiny</label>
      <label><input type="radio" name="size" value="sm"> Small</label>
      <label><input type="radio" name="size" value="med" checked> Medium</label>
      <label><input type="radio" name="size" value="lg"> Large</label>
      <label><input type="radio" name="size" value="huge"> Huge</label>
      <label><input type="radio" name="size" value="grg"> Gargantuan</label>
    </div>
  </fieldset>

  <!-- Token Disposition -->
  <fieldset class="disposition-fieldset" style="flex: 1; margin: 0;">
    <legend>Token Disposition</legend>
    <div class="form-fields" style="display: flex; flex-direction: column; gap: 5px; font-size: 0.95rem; align-items: center; justify-content: center; height: 100%;">
      <label><input type="radio" name="disposition" value="1"> Friendly</label>
      <label><input type="radio" name="disposition" value="0"> Neutral</label>
      <label><input type="radio" name="disposition" value="-1" checked> Hostile</label>
    </div>
  </fieldset>
</div>

<fieldset class="combat-stats-fieldset" style="margin-bottom: 10px;">
  <legend>Combat Attributes</legend>
  <div class="flexrow" style="gap: 10px;">
    <!-- Armor Class -->
    <div class="form-group flexcol" style="margin: 0; align-items: center;">
      <label for="ac" style="line-height: 1.2;">Armor Class</label>
      <div class="form-fields">
        <input type="number" id="ac" name="ac" value="10" step="1" required
          style="text-align: center; width: 3.5rem; height: 2.5rem; font-size: 1.25rem;">
      </div>
    </div>
    
    <!-- Health / HP -->
    <div class="form-group flexcol" style="margin: 0; align-items: center;">
      <label for="hp" style="line-height: 1.2;">Health (HP)</label>
      <div class="form-fields">
        <input type="number" id="hp" name="hp" value="10" step="1" required
          style="text-align: center; width: 3.5rem; height: 2.5rem; font-size: 1.25rem;">
      </div>
    </div>
  </div>
</fieldset>

<fieldset class="spellcasting-fieldset" style="margin-bottom: 10px;">
  <legend>Spellcasting</legend>
  <div class="flexrow" style="gap: 10px;">
    <!-- Spellcasting Ability -->
    <div class="form-group flexcol" style="margin: 0; align-items: center; flex: 1;">
      <label for="spellcasting" style="line-height: 1.2;">Ability</label>
      <div class="form-fields" style="width: 100%;">
        <select id="spellcasting" name="spellcasting" style="text-align: center; height: 2.5rem; font-size: 1.1rem; width: 100%;">
          <option value="">None</option>
          <option value="int">Intelligence</option>
          <option value="wis">Wisdom</option>
          <option value="cha">Charisma</option>
          <option value="str">Strength</option>
          <option value="dex">Dexterity</option>
          <option value="con">Constitution</option>
        </select>
      </div>
    </div>
    
    <!-- Spellcasting Level -->
    <div class="form-group flexcol" style="margin: 0; align-items: center;">
      <label for="spellLevel" style="line-height: 1.2;">Level</label>
      <div class="form-fields">
        <input type="number" id="spellLevel" name="spellLevel" value="0" min="0" step="1"
          style="text-align: center; width: 3.5rem; height: 2.5rem; font-size: 1.25rem;">
      </div>
    </div>
  </div>
</fieldset>

<!-- Compendium Item Search -->
<fieldset class="compendium-search-fieldset" style="margin-bottom: 10px; position: relative;">
  <legend>Compendium Items</legend>
  <div class="form-group flexcol" style="margin: 0;">
    <p class="notes" style="margin-bottom: 5px;">Search all compendiums for spells, weapons, and features to grant this NPC.</p>
    <div class="search-container" style="position: relative; width: 100%;">
      <input type="text" id="itemSearchQuery" placeholder="Search items..." style="width: 100%; height: 2rem; padding: 0 0.5rem; border-radius: 4px; border: 1px solid var(--color-border-light-primary);">
      <ul id="itemSearchResults" class="search-results-dropdown" style="display: none;">
        <!-- Results injected here -->
      </ul>
    </div>
  </div>
  
  <div class="form-group flexcol" style="margin-top: 10px;">
    <label>Selected Items:</label>
    <div id="selectedItemsBin" class="selected-items-bin">
      <!-- Selected Item Pills injected here -->
      <span class="empty-bin-msg" style="color: var(--color-text-light-5); font-style: italic; font-size: 0.9em;">No items selected.</span>
    </div>
  </div>
</fieldset>

<fieldset class="abilities-fieldset">
  <legend>Ability Scores</legend>
  <div class="flexrow" style="gap: 5px;">
    {{#each abilities as |label key|}}
    <div class="form-group flexcol" style="margin: 0; align-items: center;">
      <label for="ability-{{key}}" style="line-height: 1.2;">{{label}}</label>
      <div class="form-fields">
        <input type="number" id="ability-{{key}}" name="abilities.{{key}}" value="10" step="1" required
          style="text-align: center;">
      </div>
    </div>
    {{/each}}
  </div>
</fieldset>

<div class="form-group">
  <button type="button" class="create-btn" data-action="createNPC">
    <i class="fas fa-hammer"></i> Create
  </button>
</div>
</form>